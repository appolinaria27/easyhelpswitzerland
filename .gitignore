# macOS
.DS_Store
**/.DS_Store

# ── Secrets / environment ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local
.htpasswd
*.key
*.pem
*.p12
*.pfx

# ── Dependencies ──────────────────────────────────────────────────────────────
vendor/
node_modules/

# ── Logs — contain request details, IPs, errors ──────────────────────────────
logs/
*.log
error_log
php_errors.log

# ── Backups ───────────────────────────────────────────────────────────────────
backups/

# ── Runtime / temp files ──────────────────────────────────────────────────────
rate-limit/
*.tmp
*.bak
*.swp
*.swo
*~

# ── PHP server config ─────────────────────────────────────────────────────────
.user.ini
php.ini

# ── Local tooling ─────────────────────────────────────────────────────────────
.claude/

# ── Editor ────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ── OS ────────────────────────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db

# ── Client data — private PII, must never enter version control ──────────────
# Paid bookings
bookings/*.json
!bookings/.htaccess

# Pending bookings (pre-payment)
pending-bookings/

# Free consultation submissions
free-consultations/*.json
!free-consultations/.htaccess

# Admin notes, termin dates (per-booking)
admin-data/

# Bills / invoices — contain client name, email, price breakdown
bills/*.json

# ── Stripe webhook files ──────────────────────────────────────────────────────
stripe-events/*.lock
stripe-events/*.json

# ── Runtime cache ─────────────────────────────────────────────────────────────
# News cache is rebuilt automatically — no need to track
news-cache.json

# ── Design scratch files ──────────────────────────────────────────────────────
og-image-source.html

# ── PHP session files ─────────────────────────────────────────────────────────
/tmp/sess_*
sess_*
