{
  "functions": {
    "api/checkout.js":     { "memory": 256 },
    "api/webhook.js":      { "memory": 256 },
    "api/consultation.js": { "memory": 256 },
    "api/news.js":         { "memory": 256 }
  },
  "rewrites": [
    { "source": "/api/checkout",     "destination": "/api/checkout.js" },
    { "source": "/api/webhook",      "destination": "/api/webhook.js" },
    { "source": "/api/consultation", "destination": "/api/consultation.js" },
    { "source": "/api/news",         "destination": "/api/news.js" },
    { "source": "/blog.php",                  "destination": "/blog.html" },
    { "source": "/blog",                      "destination": "/blog.html" },
    { "source": "/booking.php",               "destination": "/booking.html" },
    { "source": "/booking",                   "destination": "/booking.html" },
    { "source": "/free-consultation.php",     "destination": "/free-consultation.html" },
    { "source": "/free-consultation",         "destination": "/free-consultation.html" },
    { "source": "/privacy.php",               "destination": "/privacy.html" },
    { "source": "/privacy",                   "destination": "/privacy.html" },
    { "source": "/terms.php",                 "destination": "/terms.html" },
    { "source": "/terms",                     "destination": "/terms.html" },
    { "source": "/refund-policy.php",         "destination": "/refund-policy.html" },
    { "source": "/refund-policy",             "destination": "/refund-policy.html" },
    { "source": "/success.php",               "destination": "/consultation-success.html" },
    { "source": "/consultation-success.php",  "destination": "/consultation-success.html" },
    { "source": "/consultation-success",      "destination": "/consultation-success.html" },
    { "source": "/404.php",                   "destination": "/404.html" }
  ]
}
